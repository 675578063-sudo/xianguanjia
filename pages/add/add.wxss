/* pages/add/add.wxss */

.container {
  padding: 24rpx 32rpx 260rpx;
}

/* 表单分组 */
.form-group { margin-bottom: 28rpx; }

.form-label {
  font-size: 26rpx;
  font-weight: 500;
  color: #6b7280;
  margin-bottom: 10rpx;
  display: block;
}

.req { color: #ef4444; }

/* 输入框：统一高度与内边距，避免文字裁切 */
.form-input {
  width: 100%;
  min-height: 88rpx;
  padding: 22rpx 28rpx;
  border: 1rpx solid #e5e7eb;
  border-radius: 12rpx;
  font-size: 28rpx;
  line-height: 44rpx;
  background: #ffffff;
  color: #1a1a2e;
  box-sizing: border-box;
}

/* picker 内展示文字：与输入框等高、垂直居中 */
.picker-display {
  width: 100%;
  min-height: 88rpx;
  padding: 22rpx 28rpx;
  border: 1rpx solid #e5e7eb;
  border-radius: 12rpx;
  font-size: 28rpx;
  background: #ffffff;
  color: #1a1a2e;
  box-sizing: border-box;
  display: flex;
  align-items: center;
}

.picker-display.placeholder { color: #9ca3af; }

/* 保存前到期日 + 来源预览 */
.expiry-preview {
  background: #eef2ff;
  border: 1rpx solid #c7d2fe;
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  margin-bottom: 28rpx;
}
.ep-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 6rpx 0;
}
.ep-label {
  font-size: 26rpx;
  color: #6b7280;
  font-weight: 500;
}
.ep-value {
  font-size: 30rpx;
  font-weight: 700;
  color: #1a1a2e;
}
.ep-source {
  font-size: 26rpx;
  font-weight: 600;
  color: #4f46e5;
}

/* 更多信息（选填）折叠区 */
.more-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 4rpx;
  margin: 8rpx 0 4rpx;
  border-top: 1rpx dashed #e5e7eb;
}
.more-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #374151;
}
.more-chevron {
  font-size: 32rpx;
  color: #9ca3af;
}

/* 两列表单行 */
.form-row { display: flex; }
.form-row .form-group { flex: 1; }
.form-row .form-group:first-child { margin-right: 16rpx; }

/* 日期模式分段控件 */
.segmented {
  display: flex;
  background: #f3f4f6;
  border-radius: 12rpx;
  padding: 6rpx;
}
.segmented-item {
  flex: 1;
  text-align: center;
  padding: 18rpx 0;
  font-size: 26rpx;
  color: #6b7280;
  border-radius: 8rpx;
}
.segmented-item.active {
  background: #ffffff;
  color: #4f46e5;
  font-weight: 600;
  box-shadow: 0 1rpx 4rpx rgba(0,0,0,0.08);
}

/* 分类网格 */
.category-grid {
  display: flex;
  flex-wrap: wrap;
}
.category-btn {
  width: 25%;
  padding: 16rpx 8rpx;
  border-radius: 12rpx;
  border: 1rpx solid #e5e7eb;
  background: #ffffff;
  text-align: center;
  font-size: 24rpx;
  font-weight: 500;
  color: #6b7280;
  display: flex;
  flex-direction: column;
  align-items: center;
}
.category-btn.active {
  background: #eef2ff;
  color: #4f46e5;
  border-color: #4f46e5;
}
.cat-icon { font-size: 44rpx; }

/* 存储选择 */
.storage-grid {
  display: flex;
  flex-wrap: wrap;
}
.storage-btn {
  width: 25%;
  padding: 16rpx 8rpx;
  border-radius: 12rpx;
  border: 1rpx solid #e5e7eb;
  background: #ffffff;
  text-align: center;
  font-size: 24rpx;
  font-weight: 500;
  color: #6b7280;
}
.storage-btn.active {
  background: #eef2ff;
  color: #4f46e5;
  border-color: #4f46e5;
}

/* Toggle 按钮 */
.toggle-group { display: flex; }
.toggle-btn {
  padding: 16rpx 32rpx;
  border-radius: 40rpx;
  border: 1rpx solid #e5e7eb;
  background: #ffffff;
  font-size: 26rpx;
  color: #6b7280;
  margin-right: 16rpx;
}
.toggle-btn.active {
  background: #eef2ff;
  color: #4f46e5;
  border-color: #4f46e5;
}

/* 底部固定保存栏（安全区适配） */
.save-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 300;
  display: flex;
  align-items: center;
  padding: 20rpx 32rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background: #ffffff;
  border-top: 1rpx solid #f0f0f0;
  box-shadow: 0 -4rpx 16rpx rgba(0,0,0,0.05);
}
.save-bar-btn {
  flex: 1;
  text-align: center;
  padding: 22rpx 0;
  background: #4f46e5;
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 12rpx;
  border: none;
}
.save-bar-btn::after { border: none; }
