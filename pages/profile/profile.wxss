/* pages/profile/profile.wxss - 个人中心样式 */

/* 用户信息区 */
.profile-header {
  background: linear-gradient(135deg, #4f46e5 0%, #7c3aed 100%);
  border-radius: 24rpx;
  padding: 48rpx 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 30rpx rgba(79, 70, 229, 0.2);
}

/* 未登录 */
.login-area {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.avatar-placeholder {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  overflow: hidden;
  border: 4rpx solid rgba(255,255,255,0.3);
}

.avatar-btn {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background: transparent;
  border: none;
  padding: 0;
  margin: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  position: relative;
  z-index: 10;
  overflow: hidden;
  line-height: normal;
}

.avatar-btn::after {
  border: none;
}

.avatar-img {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
}

.avatar-tip {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background: rgba(0,0,0,0.5);
  color: #fff;
  font-size: 20rpx;
  text-align: center;
  padding: 6rpx;
}

.login-text {
  color: rgba(255,255,255,0.9);
  font-size: 28rpx;
  text-align: center;
  margin-top: 16rpx;
}

/* 已登录 */
.user-info-area {
  display: flex;
  align-items: center;
}

.avatar-editable {
  position: relative;
  width: 120rpx;
  height: 120rpx;
  margin-right: 20rpx;
}

.avatar-btn-small {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: transparent;
  border: none;
  padding: 0;
  margin: 0;
  overflow: hidden;
  position: relative;
  z-index: 10;
  line-height: normal;
}

.avatar-btn-small::after {
  border: none;
}

.avatar-img-small {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  border: 3rpx solid rgba(255,255,255,0.4);
}

.edit-badge {
  position: absolute;
  bottom: 0;
  right: 0;
  width: 36rpx;
  height: 36rpx;
  background: #ffffff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 18rpx;
  color: #4f46e5;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.2);
}

.user-detail {
  flex: 1;
}

.user-name {
  color: #ffffff;
  font-size: 34rpx;
  font-weight: 600;
}

.user-id {
  color: rgba(255,255,255,0.6);
  font-size: 22rpx;
  margin-top: 4rpx;
}

.logout-btn {
  padding: 12rpx 24rpx;
  border-radius: 40rpx;
  background: rgba(255,255,255,0.2);
  color: #ffffff;
  font-size: 24rpx;
  border: 1rpx solid rgba(255,255,255,0.3);
}

/* 昵称弹窗 */
.nickname-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 999;
}

.modal-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.5);
}

.modal-content {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 600rpx;
  background: #ffffff;
  border-radius: 24rpx;
  padding: 40rpx;
  box-shadow: 0 16rpx 60rpx rgba(0,0,0,0.2);
}

.modal-title {
  font-size: 34rpx;
  font-weight: 600;
  text-align: center;
  margin-bottom: 32rpx;
}

.nickname-input {
  width: 100%;
  padding: 24rpx;
  border: 2rpx solid #e5e7eb;
  border-radius: 12rpx;
  font-size: 30rpx;
  margin-bottom: 32rpx;
}

.modal-btns {
  display: flex;
}

.modal-btn {
  flex: 1;
  padding: 24rpx;
  border-radius: 12rpx;
  text-align: center;
  font-size: 30rpx;
  font-weight: 500;
}

.modal-btn.cancel {
  background: #f3f4f6;
  color: #6b7280;
  margin-right: 16rpx;
}

.modal-btn.confirm {
  background: #4f46e5;
  color: #ffffff;
}

/* 我的统计 */
.my-stats-grid {
  display: flex;
  justify-content: space-around;
  padding: 12rpx 0;
}

.my-stat-item {
  text-align: center;
  flex: 1;
}

.my-stat-num {
  font-size: 48rpx;
  font-weight: 700;
  color: #1a1a2e;
}

.my-stat-item.danger .my-stat-num {
  color: #ef4444;
}

.my-stat-item.warning .my-stat-num {
  color: #f59e0b;
}

.my-stat-label {
  font-size: 24rpx;
  color: #9ca3af;
  margin-top: 4rpx;
}

/* 浪费金额 */
.waste-money-display {
  display: flex;
  align-items: baseline;
  padding: 12rpx 0;
}

.waste-money-value {
  font-size: 56rpx;
  font-weight: 700;
  color: #ef4444;
  margin-right: 12rpx;
}

.waste-money-desc {
  font-size: 26rpx;
  color: #9ca3af;
}

/* 设置行 */
.setting-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.setting-row:last-of-type {
  border-bottom: none;
}

.setting-label {
  font-size: 28rpx;
  color: #1a1a2e;
}

.setting-value {
  font-size: 28rpx;
  color: #4f46e5;
  font-weight: 500;
  padding: 8rpx 20rpx;
  background: #eef2ff;
  border-radius: 8rpx;
}

.subscribe-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  margin-top: 8rpx;
}

.subscribe-desc {
  font-size: 24rpx;
  color: #9ca3af;
  flex: 1;
}

.subscribe-btn {
  padding: 12rpx 24rpx;
  background: #4f46e5;
  color: #ffffff;
  font-size: 24rpx;
  border-radius: 8rpx;
  border: none;
}

.subscribe-btn::after {
  border: none;
}

/* 数据管理行 */
.action-row {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.action-row:last-child {
  border-bottom: none;
}

.action-row.danger .action-text {
  color: #ef4444;
}

.action-icon {
  font-size: 32rpx;
  margin-right: 16rpx;
}

.action-text {
  font-size: 28rpx;
  color: #1a1a2e;
  flex: 1;
}

.action-arrow {
  font-size: 32rpx;
  color: #9ca3af;
}

/* 关于 */
.about-text {
  font-size: 26rpx;
  color: #9ca3af;
  padding-top: 8rpx;
}
