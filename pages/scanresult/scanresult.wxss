/* pages/scanresult/scanresult.wxss - 复用全局表单样式，仅补充页内特有样式 */
.source-banner {
  display: flex;
  align-items: center;
  background: #eef2ff;
  border: 1rpx solid #c7d2fe;
  border-radius: 12rpx;
  padding: 16rpx 20rpx;
  margin-bottom: 24rpx;
  font-size: 24rpx;
  color: #4f46e5;
}

.source-icon {
  margin-right: 8rpx;
}

.source-text {
  font-weight: 600;
}

.source-code {
  margin-left: auto;
  color: #6b7280;
  font-size: 22rpx;
}

/* 与添加页一致的保存栏 */
.save-bar {
  position: fixed;
  left: 32rpx;
  right: 32rpx;
  bottom: 0;
  z-index: 200;
  padding: 20rpx 0 calc(20rpx + env(safe-area-inset-bottom));
  background: #f5f6f8;
}

.save-bar-btn {
  width: 100%;
  padding: 26rpx;
  border: none;
  border-radius: 16rpx;
  background: #4f46e5;
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 600;
  box-shadow: 0 8rpx 30rpx rgba(79, 70, 229, 0.3);
}
