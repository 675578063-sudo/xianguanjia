<!-- pages/scan/scan.wxml -->
<view class="scan-page">
  <view class="scan-header">
    <view class="scan-title">扫码识别</view>
    <view class="scan-sub">{{hint}}</view>
  </view>

  <!-- 取景框（wx.scanCode 为原生全屏相机，此框为说明性占位） -->
  <view class="scan-viewfinder">
    <view class="scan-frame"></view>
    <view wx:if="{{status === 'scanning'}}" class="scan-loading">识别中…</view>
  </view>

  <!-- 权限拒绝 -->
  <view wx:if="{{status === 'denied'}}" class="scan-tip-box">
    <view class="scan-tip-title">相机权限被拒绝</view>
    <view class="scan-tip-text">扫码需要相机权限。你可以前往设置开启，或使用相册识别、手动添加。</view>
    <button class="scan-btn primary" bind:tap="onOpenSetting">前往设置</button>
    <button class="scan-btn" bind:tap="onAlbumTap">从相册识别</button>
    <button class="scan-btn ghost" bind:tap="onManualTap">手动添加</button>
  </view>

  <!-- 底部操作（非拒绝状态显示） -->
  <view wx:if="{{status !== 'denied'}}" class="scan-actions">
    <view class="scan-act" bind:tap="onLightTap">
      <text class="scan-act-icon">💡</text>
      <text class="scan-act-label">开灯</text>
    </view>
    <view class="scan-act" bind:tap="onAlbumTap">
      <text class="scan-act-icon">🖼️</text>
      <text class="scan-act-label">相册</text>
    </view>
    <view class="scan-act" bind:tap="onManualTap">
      <text class="scan-act-icon">✏️</text>
      <text class="scan-act-label">手动</text>
    </view>
    <view class="scan-act" bind:tap="onRetryTap">
      <text class="scan-act-icon">🔄</text>
      <text class="scan-act-label">重扫</text>
    </view>
  </view>

  <!-- 隐私授权弹窗（摄像头/相册属隐私接口，开启隐私校验后需先授权） -->
  <privacy-popup></privacy-popup>
</view>
