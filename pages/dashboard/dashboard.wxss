/* pages/dashboard/dashboard.wxss */

.container {
  padding: 24rpx 32rpx calc(160rpx + env(safe-area-inset-bottom));
}

/* 顶部欢迎区 */
.dashboard-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 0 24rpx;
  margin-bottom: 8rpx;
}

.header-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #1a1a2e;
  line-height: 1.3;
}

.header-subtitle {
  font-size: 24rpx;
  color: #9ca3af;
  margin-top: 4rpx;
}

.header-action {
  padding: 16rpx 24rpx;
  background: #4f46e5;
  color: #ffffff;
  border-radius: 40rpx;
  font-size: 26rpx;
  font-weight: 500;
  display: flex;
  align-items: center;
  box-shadow: 0 4rpx 16rpx rgba(79, 70, 229, 0.25);
}

.header-action-icon {
  font-size: 32rpx;
  font-weight: 300;
  margin-right: 6rpx;
}

/* 统计网格 - 2x2 */
.stats-grid {
  display: flex;
  flex-wrap: wrap;
  margin-bottom: 20rpx;
}

.stat-card {
  width: calc(50% - 8rpx);
  background: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx 20rpx;
  margin-bottom: 16rpx;
  border: 1rpx solid #f0f0f0;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.stat-card:nth-child(odd) {
  margin-right: 16rpx;
}

.stat-main {
  display: flex;
  flex-direction: column;
}

.stat-value {
  font-size: 44rpx;
  font-weight: 700;
  line-height: 1.2;
}

.stat-label {
  font-size: 24rpx;
  color: #9ca3af;
  margin-top: 4rpx;
}

.stat-arrow {
  font-size: 36rpx;
  color: #d1d5db;
  font-weight: 300;
}

.stat-card.danger { border-left: 6rpx solid #ef4444; }
.stat-card.danger .stat-value { color: #ef4444; }
.stat-card.warning { border-left: 6rpx solid #f59e0b; }
.stat-card.warning .stat-value { color: #f59e0b; }
.stat-card.info { border-left: 6rpx solid #4f46e5; }
.stat-card.info .stat-value { color: #4f46e5; }
.stat-card.safe { border-left: 6rpx solid #10b981; }
.stat-card.safe .stat-value { color: #10b981; }

/* 浪费提示条 */
.waste-tip {
  display: flex;
  align-items: center;
  background: #fef3c7;
  border: 1rpx solid #fde68a;
  border-radius: 12rpx;
  padding: 16rpx 20rpx;
  margin-bottom: 20rpx;
}

.waste-tip-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
}

.waste-tip-text {
  font-size: 24rpx;
  color: #92400e;
  line-height: 1.5;
  flex: 1;
}

/* Section 区块 */
.section {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  border: 1rpx solid #f0f0f0;
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1a1a2e;
}

.section-more {
  font-size: 24rpx;
  color: #4f46e5;
}

/* 优先级列表 */
.priority-item {
  display: flex;
  align-items: center;
  padding: 18rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.priority-item:last-child {
  border-bottom: none;
}

.priority-dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  margin-right: 16rpx;
}

.priority-dot.urgent { background: #ef4444; }
.priority-dot.soon { background: #f59e0b; }
.priority-dot.ok { background: #10b981; }

.priority-info {
  flex: 1;
  min-width: 0;
}

.priority-name {
  font-size: 28rpx;
  font-weight: 500;
  color: #1a1a2e;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.priority-meta {
  font-size: 22rpx;
  color: #9ca3af;
  margin-top: 2rpx;
}

.priority-days {
  font-size: 24rpx;
  font-weight: 600;
  text-align: right;
  margin-left: 16rpx;
}

.priority-days.urgent { color: #ef4444; }
.priority-days.soon { color: #f59e0b; }
.priority-days.ok { color: #10b981; }

/* 分类概览 - 进度条形式 */
.category-row {
  display: flex;
  align-items: center;
  padding: 18rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.category-row:last-child {
  border-bottom: none;
}

.category-left {
  flex: 1;
  min-width: 0;
  margin-right: 20rpx;
}

.category-name {
  font-size: 26rpx;
  color: #374151;
  margin-bottom: 10rpx;
}

.category-bar-track {
  height: 10rpx;
  background: #f3f4f6;
  border-radius: 5rpx;
  overflow: hidden;
}

.category-bar-fill {
  height: 100%;
  border-radius: 5rpx;
}

.category-bar-fill.ok { background: #10b981; }
.category-bar-fill.expired { background: #ef4444; }

.category-right {
  flex-shrink: 0;
  text-align: right;
}

.category-num {
  font-size: 32rpx;
  font-weight: 700;
}

.category-unit {
  font-size: 22rpx;
  color: #9ca3af;
  margin-left: 2rpx;
}

.category-right.ok .category-num { color: #10b981; }
.category-right.expired .category-num { color: #ef4444; }

/* 空状态 */
.empty-state {
  text-align: center;
  padding: 80rpx 40rpx;
  color: #9ca3af;
}

.empty-state.compact {
  padding: 48rpx 40rpx;
}

.empty-icon {
  font-size: 96rpx;
  margin-bottom: 24rpx;
}

.empty-icon.small {
  font-size: 64rpx;
  margin-bottom: 16rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #6b7280;
}

.empty-hint {
  font-size: 24rpx;
  margin-top: 8rpx;
  color: #9ca3af;
}

.empty-btn {
  display: inline-block;
  margin-top: 24rpx;
  padding: 16rpx 40rpx;
  background: #4f46e5;
  color: #ffffff;
  border-radius: 40rpx;
  font-size: 26rpx;
  font-weight: 500;
}

/* 悬浮添加按钮 */
.fab-btn {
  position: fixed;
  bottom: calc(32rpx + env(safe-area-inset-bottom));
  left: 32rpx;
  right: 32rpx;
  z-index: 200;
  padding: 26rpx;
  padding-bottom: calc(26rpx + env(safe-area-inset-bottom));
  font-size: 30rpx;
  font-weight: 600;
  border: none;
  border-radius: 16rpx;
  background: #4f46e5;
  color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 30rpx rgba(79,70,229,0.3);
}

.fab-btn::after {
  border: none;
}

.fab-icon {
  font-size: 36rpx;
  font-weight: 300;
  margin-right: 12rpx;
}
