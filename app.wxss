/* app.wxss - 鲜管家全局样式 */
page {
  background-color: #f5f6f8;
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Microsoft YaHei', sans-serif;
  color: #1a1a2e;
  line-height: 1.6;
  box-sizing: border-box;
}

view, text, image, button, input, navigator, scroll-view {
  box-sizing: border-box;
}

/* 全局颜色变量（小程序不支持 CSS 变量，直接用值） */
/* primary: #4f46e5, green: #10b981, yellow: #f59e0b, red: #ef4444 */

.container {
  padding: 16rpx 32rpx 140rpx;
}

/* 统计卡片 */
.stats-grid {
  display: flex;
  flex-wrap: wrap;
  margin-bottom: 24rpx;
}

.stats-grid .stat-card:nth-child(odd) {
  margin-right: 12rpx;
}

.stat-card {
  width: calc(50% - 6rpx);
  background: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 12rpx;
  border: 1rpx solid #f0f0f0;
  box-shadow: 0 1rpx 4rpx rgba(0,0,0,0.05);
}

.stat-label {
  font-size: 24rpx;
  color: #9ca3af;
  margin-bottom: 4rpx;
}

.stat-value {
  font-size: 56rpx;
  font-weight: 700;
  line-height: 1.2;
}

.stat-unit {
  font-size: 24rpx;
  color: #6b7280;
  margin-top: 4rpx;
}

.stat-card.danger { border-left: 6rpx solid #ef4444; }
.stat-card.danger .stat-value { color: #ef4444; }
.stat-card.warning { border-left: 6rpx solid #f59e0b; }
.stat-card.warning .stat-value { color: #f59e0b; }
.stat-card.safe { border-left: 6rpx solid #10b981; }
.stat-card.safe .stat-value { color: #10b981; }
.stat-card.info { border-left: 6rpx solid #4f46e5; }
.stat-card.info .stat-value { color: #4f46e5; }

/* Section 区块 */
.section {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  border: 1rpx solid #f0f0f0;
  box-shadow: 0 1rpx 4rpx rgba(0,0,0,0.05);
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  margin-bottom: 16rpx;
}

/* 优先级列表 */
.priority-item {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.priority-item:last-child { border-bottom: none; }

.priority-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  margin-right: 16rpx;
}

.priority-dot.urgent { background: #ef4444; }
.priority-dot.soon { background: #f59e0b; }
.priority-dot.ok { background: #10b981; }

.priority-info { flex: 1; min-width: 0; }

.priority-name {
  font-size: 28rpx;
  font-weight: 500;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.priority-meta {
  font-size: 24rpx;
  color: #9ca3af;
}

.priority-days {
  font-size: 26rpx;
  font-weight: 600;
  text-align: right;
  margin-left: 16rpx;
}

.priority-days.urgent { color: #ef4444; }
.priority-days.soon { color: #f59e0b; }
.priority-days.ok { color: #10b981; }

/* 食品卡片 */
.food-card {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
  margin-bottom: 16rpx;
  border: 1rpx solid #f0f0f0;
  box-shadow: 0 1rpx 4rpx rgba(0,0,0,0.05);
  display: flex;
  align-items: center;
}

.food-card.status-expired { border-left: 6rpx solid #ef4444; background: #fee2e2; }
.food-card.status-urgent { border-left: 6rpx solid #ef4444; }
.food-card.status-soon { border-left: 6rpx solid #f59e0b; }
.food-card.status-ok { border-left: 6rpx solid #10b981; }
.food-card.status-safe { border-left: 6rpx solid #6b7280; }

.food-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  background: #f3f4f6;
  margin-right: 16rpx;
}

.food-info { flex: 1; min-width: 0; }

.food-name {
  font-size: 28rpx;
  font-weight: 600;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.food-meta {
  font-size: 24rpx;
  color: #9ca3af;
  margin-top: 4rpx;
}

.days-badge {
  font-size: 24rpx;
  font-weight: 600;
  padding: 6rpx 16rpx;
  border-radius: 40rpx;
  display: inline-block;
  margin-left: 16rpx;
}

.days-badge.expired { background: #fee2e2; color: #ef4444; }
.days-badge.urgent { background: #fee2e2; color: #ef4444; }
.days-badge.soon { background: #fef3c7; color: #f59e0b; }
.days-badge.ok { background: #d1fae5; color: #10b981; }
.days-badge.safe { background: #f3f4f6; color: #6b7280; }

/* 空状态 */
.empty-state {
  text-align: center;
  padding: 80rpx 40rpx;
  color: #9ca3af;
}

.empty-icon { font-size: 96rpx; margin-bottom: 24rpx; }
.empty-text { font-size: 28rpx; }
.empty-hint { font-size: 24rpx; margin-top: 8rpx; }

/* 提醒项 */
.reminder-item {
  display: flex;
  align-items: center;
  padding: 16rpx;
  background: #ffffff;
  border-radius: 12rpx;
  margin-bottom: 12rpx;
  border: 1rpx solid #f0f0f0;
}

.reminder-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  margin-right: 16rpx;
}

.reminder-icon.expired { background: #fee2e2; }
.reminder-icon.soon { background: #fef3c7; }
.reminder-icon.ok { background: #d1fae5; }

.reminder-info { flex: 1; }
.reminder-name { font-size: 28rpx; font-weight: 500; }
.reminder-detail { font-size: 24rpx; color: #9ca3af; }
.reminder-date { font-size: 26rpx; font-weight: 600; margin-left: 16rpx; }
.reminder-date.expired { color: #ef4444; }
.reminder-date.soon { color: #f59e0b; }

/* 柱状图 */
.waste-bar {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.waste-bar:last-child { border-bottom: none; }

.waste-cat { font-size: 26rpx; font-weight: 500; width: 120rpx; }
.waste-track {
  flex: 1;
  height: 40rpx;
  background: #f3f4f6;
  border-radius: 20rpx;
  position: relative;
  overflow: hidden;
  margin-left: 16rpx;
}

.waste-fill {
  height: 100%;
  border-radius: 20rpx;
}

.waste-num { font-size: 24rpx; color: #9ca3af; width: 80rpx; text-align: right; margin-left: 16rpx; }

/* 表单 */
.form-group { margin-bottom: 24rpx; }

.form-label {
  font-size: 26rpx;
  font-weight: 500;
  color: #6b7280;
  margin-bottom: 8rpx;
  display: block;
}

.form-input {
  width: 100%;
  min-height: 88rpx;
  padding: 22rpx 28rpx;
  border: 1rpx solid #e5e7eb;
  border-radius: 12rpx;
  font-size: 28rpx;
  line-height: 44rpx;
  background: #ffffff;
  color: #1a1a2e;
  box-sizing: border-box;
}

/* picker 内展示文字：与输入框等高、垂直居中 */
.picker-display {
  width: 100%;
  min-height: 88rpx;
  padding: 22rpx 28rpx;
  border: 1rpx solid #e5e7eb;
  border-radius: 12rpx;
  font-size: 28rpx;
  background: #ffffff;
  color: #1a1a2e;
  box-sizing: border-box;
  display: flex;
  align-items: center;
}

.picker-display.placeholder { color: #9ca3af; }

.form-row {
  display: flex;
}

.form-row .form-group { flex: 1; }
.form-row .form-group:first-child { margin-right: 16rpx; }

/* 分类网格 - 使用 flex 替代 grid */
.category-grid {
  display: flex;
  flex-wrap: wrap;
  margin-bottom: 24rpx;
}

.category-btn {
  width: 25%;
  padding: 16rpx 8rpx;
  border-radius: 12rpx;
  border: 1rpx solid #e5e7eb;
  background: #ffffff;
  text-align: center;
  font-size: 24rpx;
  font-weight: 500;
  color: #6b7280;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.category-btn.active {
  background: #eef2ff;
  color: #4f46e5;
  border-color: #4f46e5;
}

.cat-icon { font-size: 44rpx; }

/* 存储选择 - 使用 flex 替代 grid */
.storage-grid {
  display: flex;
  flex-wrap: wrap;
}

.storage-btn {
  width: 25%;
  padding: 16rpx 8rpx;
  border-radius: 12rpx;
  border: 1rpx solid #e5e7eb;
  background: #ffffff;
  text-align: center;
  font-size: 24rpx;
  font-weight: 500;
  color: #6b7280;
}

.storage-btn.active {
  background: #eef2ff;
  color: #4f46e5;
  border-color: #4f46e5;
}

/* Toggle 按钮 */
.toggle-group {
  display: flex;
}

.toggle-btn {
  padding: 16rpx 32rpx;
  border-radius: 40rpx;
  border: 1rpx solid #e5e7eb;
  background: #ffffff;
  font-size: 26rpx;
  color: #6b7280;
  margin-right: 16rpx;
}

.toggle-btn.active {
  background: #eef2ff;
  color: #4f46e5;
  border-color: #4f46e5;
}

/* 详情行 */
.detail-row {
  display: flex;
  justify-content: space-between;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.detail-row:last-child { border-bottom: none; }
.detail-label { font-size: 26rpx; color: #9ca3af; }
.detail-value { font-size: 28rpx; font-weight: 500; }

/* 搜索栏 */
.search-bar {
  display: flex;
  margin-bottom: 20rpx;
}

.search-input {
  flex: 1;
  min-height: 88rpx;
  padding: 22rpx 28rpx;
  line-height: 44rpx;
  border: 1rpx solid #e5e7eb;
  border-radius: 12rpx;
  font-size: 28rpx;
  background: #ffffff;
  color: #1a1a2e;
  box-sizing: border-box;
}

/* 筛选按钮 */
.filter-bar {
  display: flex;
  flex-wrap: wrap;
  margin-bottom: 20rpx;
}

.filter-btn {
  padding: 12rpx 28rpx;
  font-size: 26rpx;
  border-radius: 40rpx;
  border: 1rpx solid #e5e7eb;
  background: #ffffff;
  color: #6b7280;
  margin-right: 12rpx;
}

.filter-btn.active {
  background: #eef2ff;
  color: #4f46e5;
  border-color: #4f46e5;
}

/* FAB 添加按钮 */
.fab-btn {
  position: fixed;
  bottom: calc(32rpx + env(safe-area-inset-bottom));
  left: 32rpx;
  right: 32rpx;
  z-index: 200;
  padding: 28rpx;
  padding-bottom: calc(28rpx + env(safe-area-inset-bottom));
  font-size: 32rpx;
  font-weight: 600;
  border: none;
  border-radius: 16rpx;
  background: #4f46e5;
  color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 30rpx rgba(79,70,229,0.3);
}
